# ==============================================================
# TRIMO – Environment Variables
# ==============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it is in .gitignore.
# ==============================================================

# ----- Convex -----
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# ----- Clerk Auth -----
# Leave empty in development to use Clerk keyless mode (no signup needed)
# Get your key from https://dashboard.clerk.com after claiming your instance
VITE_CLERK_PUBLISHABLE_KEY=
